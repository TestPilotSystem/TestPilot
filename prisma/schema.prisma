datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

enum Role {
  ADMIN
  STUDENT
}

enum RequestStatus {
  PENDING
  APPROVED
  REJECTED
}

enum TestType {
  BASIC
  ERROR
  CUSTOM
}

enum NotificationType {
  ACCOUNT_APPROVED
  ACCOUNT_REJECTED
  ADMIN_MESSAGE
  TEST_SUMMARY
}

model User {
  id                 Int       @id @default(autoincrement())
  email              String    @unique
  password           String
  role               Role      @default(STUDENT)
  mustChangePassword Boolean   @default(false)
  avatarId           String?

  dni         String?   @unique
  firstName   String
  lastName    String
  dateOfBirth DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  requests     Request[]
  userTests    UserTest[]
  chatMessages   ChatMessage[]
  notifications  Notification[]
  aiToken        AiToken?
}

model Request {
  id         Int           @id @default(autoincrement())
  status     RequestStatus @default(PENDING)
  adminNotes String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  userId Int
  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Topic {
  id    String @id @default(cuid())
  name  String @unique
  tests Test[]
}

model Test {
  id        String   @id @default(cuid())
  type      TestType @default(BASIC)
  name      String?  // Optional name for ERROR/CUSTOM tests
  createdAt DateTime @default(now())

  topicId   String?
  topic     Topic?   @relation(fields: [topicId], references: [id])
  
  userId    Int?     // Owner for ERROR/CUSTOM tests (null for BASIC)
  
  questions Question[]
  attempts  UserTest[]

  @@index([topicId])
  @@index([userId])
}

model Question {
  id     String @id @default(cuid())
  testId String
  test   Test   @relation(fields: [testId], references: [id], onDelete: Cascade)

  enunciado         String  @db.Text
  opciones          Json
  respuestaCorrecta String  @db.Text
  explicacion       String? @db.Text

  userResponses UserResponse[]

  @@index([testId])
}

model UserTest {
  id          String    @id @default(cuid())
  userId      Int
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  testId      String
  test        Test      @relation(fields: [testId], references: [id], onDelete: Cascade)
  
  score            Int?
  timeSpentSeconds Int?
  completed        Boolean   @default(false)
  completedAt      DateTime?

  responses   UserResponse[]

  @@index([userId])
  @@index([testId])
}

model UserResponse {
  id            String       @id @default(cuid())
  userTestId    String
  userTest      UserTest     @relation(fields: [userTestId], references: [id], onDelete: Cascade)
  questionId    String
  question      Question     @relation(fields: [questionId], references: [id], onDelete: Cascade)
  
  respuestaDada String
  esCorrecta    Boolean
  
  isRectified   Boolean @default(false)

  @@index([userTestId])
  @@index([questionId])
}

model ChatMessage {
  id        String   @id @default(cuid())
  userId    Int
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  role      String
  content   String   @db.Text
  createdAt DateTime @default(now())

  @@index([userId])
}

model ChatConfig {
  id              String   @id @default("default")
  tone            String   @default("formal")
  useStudentNames Boolean  @default(false)
  updatedAt       DateTime @updatedAt
}

model Notification {
  id        String           @id @default(cuid())
  userId    Int
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  title     String
  body      String           @db.Text
  type      NotificationType
  read      Boolean          @default(false)
  emailSent Boolean          @default(false)

  createdAt DateTime         @default(now())

  @@index([userId])
  @@index([userId, read])
}

model AiToken {
  id        Int          @id @default(autoincrement())
  userId    Int          @unique @map("user_id")
  user      User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  token     String       @unique @db.VarChar(64)
  createdAt DateTime     @default(now()) @map("created_at")
  requests  AiRequest[]
  @@map("ai_tokens")
}
model AiRequest {
  id        Int      @id @default(autoincrement())
  tokenId   Int      @map("token_id")
  createdAt DateTime @default(now()) @map("created_at")
  token     AiToken  @relation(fields: [tokenId], references: [id], onDelete: Cascade)
  @@map("ai_requests")
}